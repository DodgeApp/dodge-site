# Copy to .env.local for local testing with: npm run dev:vercel
# Add the same variables in Vercel → Project → Settings → Environment Variables

# Required — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Where support submissions are delivered
SUPPORT_TO_EMAIL=support@dodgeapp.com

# Must use a domain verified in Resend (see README)
# For quick tests only, Resend allows: onboarding@resend.dev
SUPPORT_FROM_EMAIL=Dodge Support <onboarding@resend.dev>
